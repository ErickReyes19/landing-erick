---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Portafolio Full Stack | Astro Edition',
	description = 'Portafolio profesional de desarrollador Full Stack construido con Astro.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #070b14;
		--bg-soft: #0f1727;
		--text: #ecf0ff;
		--muted: #9ba7c7;
		--primary: #7c8cff;
		--accent: #52f2c8;
		--card-border: rgba(124, 140, 255, 0.26);
		--shadow: 0 20px 50px rgba(6, 10, 28, 0.5);
		font-family: 'Inter', 'Avenir Next', 'Segoe UI', sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		background: radial-gradient(circle at 10% -10%, #1a2a52 0%, transparent 50%),
			radial-gradient(circle at 100% 10%, #273884 0%, transparent 40%), var(--bg);
		color: var(--text);
		scroll-behavior: smooth;
	}

	a {
		color: inherit;
	}
</style>
