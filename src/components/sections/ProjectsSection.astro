---
interface Project {
	title: string;
	description: string;
	stack: string[];
	url: string;
	year: string;
}

interface Props {
	projects: Project[];
}

const { projects } = Astro.props;
---

<section id="proyectos" class="section">
	<div class="heading-row">
		<h3>Últimos proyectos</h3>
		<p>Incluye tus trabajos recientes y enlaces para verlos en vivo.</p>
	</div>
	<div class="projects-grid">
		{
			projects.map((project) => (
				<article class="project-card">
					<small>{project.year}</small>
					<h4>{project.title}</h4>
					<p>{project.description}</p>
					<div class="project-stack">
						{project.stack.map((item) => <span>{item}</span>)}
					</div>
					<a href={project.url} target="_blank" rel="noreferrer">Ver proyecto ↗</a>
				</article>
			))
		}
	</div>
</section>

<style>
	.section {
		padding: 3rem 0;
	}

	.heading-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
		flex-wrap: wrap;
	}

	.heading-row p,
	.project-card p {
		color: var(--muted);
		line-height: 1.7;
	}

	.projects-grid {
		margin-top: 1.4rem;
		display: grid;
		gap: 1.2rem;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.project-card {
		position: relative;
		padding: 1.5rem;
		border-radius: 1.2rem;
		border: 1px solid rgba(124, 140, 255, 0.25);
		background:
			radial-gradient(circle at top right, rgba(82, 242, 200, 0.12), transparent 45%),
			linear-gradient(155deg, rgba(10, 16, 31, 0.98), rgba(18, 30, 54, 0.75));
		box-shadow: var(--shadow);
		display: grid;
		gap: 0.8rem;
		transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
	}

	.project-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		padding: 1px;
		background: linear-gradient(160deg, rgba(82, 242, 200, 0.45), rgba(124, 140, 255, 0.3));
		-webkit-mask:
			linear-gradient(#fff 0 0) content-box,
			linear-gradient(#fff 0 0);
		-webkit-mask-composite: xor;
		mask-composite: exclude;
		pointer-events: none;
		opacity: 0.45;
	}

	.project-card:hover {
		transform: translateY(-6px);
		border-color: rgba(82, 242, 200, 0.45);
		box-shadow: 0 20px 36px rgba(4, 9, 20, 0.52);
	}

	.project-card small {
		color: var(--accent);
		font-weight: 600;
	}

	.project-card h4 {
		margin: 0;
		font-size: 1.1rem;
	}

	.project-stack {
		display: flex;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.project-stack span {
		padding: 0.45rem 0.72rem;
		border-radius: 999px;
		font-size: 0.84rem;
		border: 1px solid rgba(124, 140, 255, 0.35);
		background: rgba(124, 140, 255, 0.09);
	}

	.project-card a {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-weight: 600;
		text-decoration: none;
		color: #b5d4ff;
		transition: transform 0.2s ease, color 0.2s ease;
	}

	.project-card a:hover {
		transform: translateX(4px);
		color: #d0fff2;
	}
</style>
