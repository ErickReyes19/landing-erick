---
import Layout from '../layouts/Layout.astro';

const tools = [
	'Next.js',
	'Astro',
	'Laravel',
	'Flutter',
	'C#',
	'MySQL',
	'PostgreSQL',
	'Prisma ORM',
	'TypeScript',
	'Docker'
];

const stats = [
	{ value: '8+', label: 'años construyendo productos digitales' },
	{ value: '35+', label: 'proyectos entregados end-to-end' },
	{ value: '99%', label: 'foco en performance y UX' }
];

const projects = [
	{
		title: 'Finops Vision Dashboard',
		description:
			'Plataforma para monitoreo financiero en tiempo real con paneles de métricas, alertas inteligentes y reportes exportables.',
		stack: ['Astro', 'TypeScript', 'Prisma', 'MySQL']
	},
	{
		title: 'AI Commerce Assistant',
		description:
			'Suite omnicanal con automatizaciones para ventas y soporte, integrando catálogo, pagos y analítica de comportamiento.',
		stack: ['Next.js', 'Laravel API', 'Redis', 'PostgreSQL']
	},
	{
		title: 'Mobile Field Ops',
		description:
			'Aplicación móvil para equipos en campo con tareas offline-first, tracking de rutas y sincronización segura.',
		stack: ['Flutter', '.NET', 'SQLite', 'Azure']
	}
];

const experience = [
	{
		year: '2026',
		role: 'Full Stack Architect (Freelance)',
		detail: 'Diseño de soluciones multiplataforma, priorizando escalabilidad, observabilidad y UX premium.'
	},
	{
		year: '2024',
		role: 'Senior Product Engineer',
		detail: 'Lideré la evolución de un ecosistema SaaS con enfoque en rendimiento y flujos de conversión.'
	},
	{
		year: '2022',
		role: 'Frontend + Backend Consultant',
		detail: 'Implementé arquitecturas modulares para startups de fintech, edtech y logística.'
	}
];
---

<Layout title="Portafolio Full Stack | Erick" description="Portafolio profesional Full Stack construido con Astro.">
	<div class="noise" aria-hidden="true"></div>
	<header class="topbar container">
		<strong>ERICK.dev</strong>
		<nav>
			<a href="#proyectos">Proyectos</a>
			<a href="#experiencia">Experiencia</a>
			<a href="#contacto">Contacto</a>
		</nav>
	</header>

	<main class="container">
		<section class="hero">
			<p class="badge">Disponible para proyectos remotos</p>
			<h1>Desarrollador Full Stack que convierte ideas complejas en experiencias impecables.</h1>
			<p class="lead">
				Soy especialista en construir productos web y móviles de alto impacto, combinando ingeniería
				escalable, diseño orientado a negocio y una UX/UI premium.
			</p>
			<div class="cta-group">
				<a class="btn primary" href="#contacto">Trabajemos juntos</a>
				<a class="btn ghost" href="#proyectos">Ver casos destacados</a>
			</div>
		</section>

		<section class="stats-grid">
			{
				stats.map((item) => (
					<article class="glass-card">
						<h2>{item.value}</h2>
						<p>{item.label}</p>
					</article>
				))
			}
		</section>

		<section class="section">
			<h3>Stack principal</h3>
			<div class="chips">
				{tools.map((tool) => <span>{tool}</span>)}
			</div>
		</section>

		<section id="proyectos" class="section">
			<div class="heading-row">
				<h3>Proyectos destacados</h3>
				<p>Datos de ejemplo para versión inicial (V1).</p>
			</div>
			<div class="projects-grid">
				{
					projects.map((project) => (
						<article class="project-card">
							<h4>{project.title}</h4>
							<p>{project.description}</p>
							<div class="project-stack">
								{project.stack.map((item) => <span>{item}</span>)}
							</div>
						</article>
					))
				}
			</div>
		</section>

		<section id="experiencia" class="section">
			<h3>Trayectoria</h3>
			<div class="timeline">
				{
					experience.map((item) => (
						<article>
							<small>{item.year}</small>
							<h4>{item.role}</h4>
							<p>{item.detail}</p>
						</article>
					))
				}
			</div>
		</section>

		<section id="contacto" class="section contact">
			<h3>¿Listo para construir algo grande?</h3>
			<p>
				Puedo ayudarte a crear una plataforma veloz, escalable y visualmente extraordinaria.
				Reemplaza este texto con tu información real cuando lo desees.
			</p>
			<a class="btn primary" href="mailto:hola@erick.dev">hola@erick.dev</a>
		</section>
	</main>
</Layout>

<style>
	.container {
		width: min(1120px, 92%);
		margin-inline: auto;
	}

	.noise {
		position: fixed;
		inset: 0;
		pointer-events: none;
		opacity: 0.18;
		background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0);
		background-size: 28px 28px;
		mask: linear-gradient(to bottom, black 15%, transparent 90%);
	}

	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.2rem 0;
		position: sticky;
		top: 0;
		backdrop-filter: blur(12px);
		z-index: 10;
	}

	nav {
		display: flex;
		gap: 1rem;
	}

	nav a {
		text-decoration: none;
		font-size: 0.95rem;
		color: var(--muted);
	}

	nav a:hover {
		color: white;
	}

	.hero {
		padding: 4.5rem 0 2rem;
	}

	.badge {
		display: inline-flex;
		padding: 0.38rem 0.8rem;
		border-radius: 999px;
		background: rgba(82, 242, 200, 0.12);
		border: 1px solid rgba(82, 242, 200, 0.4);
		color: #b6ffec;
		font-size: 0.84rem;
	}

	h1 {
		font-size: clamp(2.15rem, 7vw, 4.25rem);
		line-height: 1.05;
		margin: 1rem 0;
		max-width: 16ch;
	}

	.lead {
		color: var(--muted);
		font-size: 1.05rem;
		max-width: 58ch;
		line-height: 1.75;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.btn {
		padding: 0.76rem 1.1rem;
		border-radius: 0.7rem;
		text-decoration: none;
		font-weight: 600;
	}

	.btn.primary {
		background: linear-gradient(120deg, var(--primary), #00b3ff);
		box-shadow: var(--shadow);
	}

	.btn.ghost {
		border: 1px solid var(--card-border);
		background: rgba(15, 23, 39, 0.55);
	}

	.stats-grid,
	.projects-grid,
	.timeline {
		display: grid;
		gap: 1rem;
	}

	.stats-grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}

	.glass-card,
	.project-card,
	.timeline article,
	.contact {
		border-radius: 1rem;
		border: 1px solid var(--card-border);
		background: linear-gradient(140deg, rgba(9, 14, 27, 0.94), rgba(17, 26, 46, 0.65));
		box-shadow: var(--shadow);
	}

	.glass-card {
		padding: 1.5rem;
	}

	.glass-card h2 {
		font-size: 2.1rem;
		margin: 0;
	}

	.glass-card p,
	.project-card p,
	.timeline p,
	.heading-row p,
	.contact p {
		color: var(--muted);
		line-height: 1.7;
	}

	.section {
		padding: 3rem 0;
	}

	.section h3 {
		font-size: 1.7rem;
		margin-top: 0;
	}

	.chips,
	.project-stack {
		display: flex;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.chips span,
	.project-stack span {
		padding: 0.45rem 0.72rem;
		border-radius: 999px;
		font-size: 0.84rem;
		border: 1px solid rgba(124, 140, 255, 0.35);
		background: rgba(124, 140, 255, 0.09);
	}

	.heading-row {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
		flex-wrap: wrap;
	}

	.projects-grid {
		margin-top: 1rem;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
	}

	.project-card,
	.timeline article,
	.contact {
		padding: 1.4rem;
	}

	.project-card h4,
	.timeline h4 {
		margin: 0.2rem 0 0.7rem;
		font-size: 1.1rem;
	}

	.timeline article {
		position: relative;
		overflow: hidden;
	}

	.timeline small {
		color: var(--accent);
		font-weight: 600;
	}

	.contact {
		margin-bottom: 3rem;
	}

	@media (max-width: 720px) {
		nav {
			display: none;
		}

		.hero {
			padding-top: 2.8rem;
		}
	}
</style>
