---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/sections/TopBar.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import StatsSection from '../components/sections/StatsSection.astro';
import StackSection from '../components/sections/StackSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import GithubSection from '../components/sections/GithubSection.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import { experience, githubProfile, projects, stats, tools } from '../data/portfolio';
---

<Layout title="Portafolio Full Stack | Erick" description="Portafolio profesional Full Stack construido con Astro.">
	<div class="noise" aria-hidden="true"></div>
	<TopBar />

	<main class="container">
		<HeroSection />
		<StatsSection stats={stats} />
		<StackSection tools={tools} />
		<ProjectsSection projects={projects} />
		<GithubSection githubProfile={githubProfile} />
		<ExperienceSection experience={experience} />
		<ContactSection />
	</main>
</Layout>

<style>
	.container {
		width: min(1120px, 92%);
		margin-inline: auto;
	}

	.noise {
		position: fixed;
		inset: 0;
		pointer-events: none;
		opacity: 0.18;
		background-image: radial-gradient(circle at 1px 1px, #fff 1px, transparent 0);
		background-size: 28px 28px;
		mask: linear-gradient(to bottom, black 15%, transparent 90%);
	}
</style>
